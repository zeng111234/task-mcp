{
  "hooks": {
    "PostToolUse": [
      {
        "match": "write_file|edit_file|multi_edit",
        "command": "node .reasonix/hooks/checkpoint-hook.js",
        "description": "写文件后提醒调用 checkpoint"
      },
      {
        "match": "run_command",
        "command": "node .reasonix/hooks/checkpoint-hook.js",
        "description": "test/build 后拦截，要求调用 checkpoint"
      }
    ]
  }
}
